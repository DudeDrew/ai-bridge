# AI Bridge — Environment Variables
# Copy this file to .env and fill in your values for local development.
# On Render.com, set these in the Dashboard → Environment tab.

# ── Authentication ────────────────────────────────────────────────────────────
# Auto-generated by Render on first deploy. Set any random string for local dev.
BRIDGE_API_KEY=your-secret-api-key-here

# ── Database ──────────────────────────────────────────────────────────────────
# Provided automatically by Render PostgreSQL add-on.
# For local dev, point to a local PostgreSQL instance.
DATABASE_URL=postgresql://bridge_user:password@localhost:5432/ai_bridge

# ── OpenAI ────────────────────────────────────────────────────────────────────
# Create at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ── Anthropic / Claude ────────────────────────────────────────────────────────
# Create at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# ── Notion ────────────────────────────────────────────────────────────────────
# Create an internal integration at: https://www.notion.so/my-integrations
# Then share your target database/pages with the integration.
NOTION_TOKEN=secret_...

# ── Pinecone ──────────────────────────────────────────────────────────────────
# Create at: https://app.pinecone.io — API Keys section
PINECONE_API_KEY=pcsk_...

# ── Obsidian Local REST API ───────────────────────────────────────────────────
# Install the "Local REST API" community plugin in Obsidian.
# API key is shown in the plugin settings panel.
OBSIDIAN_API_KEY=your-obsidian-api-key

# Base URL of the Obsidian Local REST API (default port is 27123).
# Change the host if Obsidian is running on a different machine.
OBSIDIAN_API_URL=http://localhost:27123

# ── Flask ─────────────────────────────────────────────────────────────────────
# Use 'production' on Render, 'development' locally for debug mode + reloader.
FLASK_ENV=development
